# MongoDB (Atlas) connection string
# Example: mongodb+srv://<user>:<password>@cluster0.abcd.mongodb.net/fbn_xai_system?retryWrites=true&w=majority
MONGO_URI=

# Cloudinary credentials (for storing uploaded files in the cloud)
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Toggle cloud uploads. Set to 'false' to use local disk uploads instead.
# Default behavior: cloud uploads enabled if Cloudinary creds present.
USE_CLOUDINARY=true

# Other optional settings
PORT=5000
