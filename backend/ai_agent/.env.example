# Copy this file to .env and fill the keys before running the agent
# Set one of LLM providers: google / openai / ollama / mock
LLM_PROVIDER=google

# API keys (set at least one provider's key)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional: override model names
GOOGLE_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# MongoDB connection (optional). If not using MongoDB you can leave default.
MONGO_URI=mongodb://localhost:27017

# Secret used for JWT in the agent
SECRET_KEY=change_this_to_a_secret

# Port for the FastAPI agent (optional)
PORT=8000
