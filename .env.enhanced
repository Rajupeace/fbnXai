# Enhanced VUAI Agent Environment Configuration

# MongoDB Configuration (Choose one)
# Option 1: MongoDB Atlas (Cloud)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vuai_knowledge_system

# Option 2: Local MongoDB
# MONGO_URI=mongodb://127.0.0.1:27017/vuai_knowledge_system

# Database Connection Settings
MONGO_CONNECT_ATTEMPTS=5
MONGO_RETRY_DELAY_MS=2000
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=0

# LLM API Keys (Choose one or more)
# OpenAI / OpenRouter
OPENAI_API_KEY=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

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# LLM Configuration
LLM_PROVIDER=openrouter
MODEL_NAME=openai/gpt-4o-mini
TEMPERATURE=0.3

# Server Configuration
PORT=3000
NODE_ENV=development

# LangChain Configuration
LANGCHAIN_VERBOSE=true
LANGCHAIN_TRACING_V2=false

# Knowledge Base Configuration
KNOWLEDGE_DIR=./knowledge
AUTO_LINK_KNOWLEDGE=true
VECTORIZE_KNOWLEDGE=true

# Performance Settings
CACHE_SIZE=1000
RESPONSE_TIMEOUT=10000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5000

# Security Settings
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
HELMET_ENABLED=true
COMPRESSION_ENABLED=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/vuai-agent.log

# Development Settings
DEBUG=false
AUTO_RESTART=true
